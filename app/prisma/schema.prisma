generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum QueueItemType {
  BOOKING
  WALK_IN
  MANUAL
}

enum QueueItemStatus {
  CONFIRMED
  ARRIVED
  WAITING
  LATE
  IN_PROGRESS
  DONE
  CANCELLED
  NO_SHOW
}

enum QueueCreatedBy {
  CUSTOMER
  OWNER
}

enum TimeBlockType {
  BREAK
  CLOSED
  MANUAL_BLOCK
}

enum NotificationChannel {
  LINE
  SMS
  MANUAL
  NONE
}

enum NotificationType {
  BOOKING_CONFIRMED
  QUEUE_CREATED
  REMINDER
  CONFIRM_COMING
  QUEUE_NEAR
  LATE
  CANCELLED
  NO_SHOW
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum QueueEntrySource {
  LINE
  SHOP_QR
  OWNER_SHARED_LINK
  IN_SHOP
  UNKNOWN
}

enum PilotQueueClassification {
  PRE_PILOT
  REAL
  TEST_SMOKE
  TRAINING
  EXCLUDED_OTHER
}

enum QueueEventType {
  QUEUE_CREATED
  STATUS_CHANGED
  QUEUE_RESTORED
  QUEUE_REORDERED
  SCHEDULE_CHANGED
  SERVICE_CHANGED
  OWNER_OVERRIDE
  EVIDENCE_CORRECTION
}

enum QueueEventActor {
  CUSTOMER
  OWNER
  SYSTEM
  OPERATOR
}

enum QueueEventMutationSource {
  PUBLIC_BOOKING
  PUBLIC_WALK_IN
  OWNER_WALK_IN
  OWNER_STATUS_ACTION
  OWNER_RESTORE_ACTION
  OWNER_REORDER_ACTION
  OWNER_EDIT_ACTION
  OPERATOR_CORRECTION
}

enum QueueEventReason {
  CREATED
  OWNER_REQUEST
  REPLACED_IN_PROGRESS
  RESTORED
  REORDER_UP
  REORDER_DOWN
  REORDER_BOTTOM
  SCHEDULE_EDIT
  SERVICE_EDIT
  DETAILS_EDIT
  EVIDENCE_CORRECTION
}

enum QueueEventRole {
  PRIMARY
  AUTO_DEMOTION
  CORRECTION
}

enum QueueReorderIntent {
  UP
  DOWN
  BOTTOM
}

enum QueueMutationOutcome {
  APPLIED
  NO_OP
}

enum NotificationAudience {
  CUSTOMER
  OWNER
}

enum NotificationSkipReason {
  NO_CUSTOMER_RECIPIENT
  NO_OWNER_RECIPIENT
  LINE_TOKEN_MISSING
}

enum EvidenceHoldReason {
  INCIDENT
  CUSTOMER_DISPUTE
  LEGAL
}

model Customer {
  id             String            @id @default(cuid())
  name           String
  phone          String?
  lineUserId     String?           @unique
  note           String?
  totalBookings  Int               @default(0)
  completedCount Int               @default(0)
  lateCount      Int               @default(0)
  noShowCount    Int               @default(0)
  cancelledCount Int               @default(0)
  queueItems     QueueItem[]
  notifications  NotificationLog[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Service {
  id              String      @id @default(cuid())
  name            String
  durationMinutes Int
  priceCents      Int?
  isActive        Boolean     @default(true)
  sortOrder       Int         @default(0)
  queueItems      QueueItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model QueueItem {
  id                     String                   @id @default(cuid())
  publicToken            String                   @unique @default(uuid())
  type                   QueueItemType
  status                 QueueItemStatus          @default(CONFIRMED)
  customerId             String?
  customer               Customer?                @relation(fields: [customerId], references: [id])
  customerNameSnapshot   String
  phoneSnapshot          String?
  lineUserIdSnapshot     String?
  serviceId              String?
  service                Service?                 @relation(fields: [serviceId], references: [id])
  serviceNameSnapshot    String
  serviceDurationMinutes Int
  date                   DateTime
  startAt                DateTime?
  estimatedAt            DateTime?
  arrivedAt              DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  noShowAt               DateTime?
  confirmedComingAt      DateTime?
  note                   String?
  ownerNote              String?
  sortOrder              Int?
  createdBy              QueueCreatedBy           @default(CUSTOMER)
  entrySource            QueueEntrySource         @default(UNKNOWN)
  quotedEstimatedAt      DateTime?
  quotedWaitMinutes      Int?
  pilotClassification    PilotQueueClassification @default(PRE_PILOT)
  pilotCohortId          String?
  pilotCohort            PilotCohort?             @relation(fields: [pilotCohortId], references: [id], onDelete: Restrict)
  pilotReleaseSegment    String?
  notifications          NotificationLog[]
  queueEvents            QueueEvent[]
  pilotOperations        QueueMutationOperation[] @relation("PrimaryQueueOperation")
  evidenceHolds          EvidenceHold[]
  classificationAudits   PilotClassificationAudit[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([date, status])
  @@index([startAt])
  @@index([sortOrder])
}

model TimeBlock {
  id        String        @id @default(cuid())
  date      DateTime
  startAt   DateTime
  endAt     DateTime
  reason    String
  type      TimeBlockType @default(MANUAL_BLOCK)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([date, startAt])
}

model NotificationLog {
  id               String                  @id @default(cuid())
  queueItemId      String?
  queueItem        QueueItem?              @relation(fields: [queueItemId], references: [id])
  customerId       String?
  customer         Customer?               @relation(fields: [customerId], references: [id])
  channel          NotificationChannel
  type             NotificationType
  status           NotificationStatus      @default(PENDING)
  recipient        String?
  messagePreview   String
  sentAt           DateTime?
  error            String?
  audience         NotificationAudience?
  skipReason       NotificationSkipReason?
  businessEventKey String?
  attemptNumber    Int?
  pilotCohortId    String?
  pilotCohort      PilotCohort?            @relation(fields: [pilotCohortId], references: [id], onDelete: Restrict)
  operationId      String?
  operation        QueueMutationOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)
  createdAt        DateTime                @default(now())

  @@unique([businessEventKey, audience, attemptNumber])
  @@index([queueItemId])
  @@index([customerId])
  @@index([status])
  @@index([audience, status, createdAt])
  @@index([pilotCohortId, createdAt])
}

model ShopSettings {
  id                           String   @id @default(cuid())
  shopName                     String
  timezone                     String   @default("Asia/Bangkok")
  openDays                     Json
  businessHours                Json
  defaultGracePeriodMinutes    Int      @default(15)
  defaultReminderMinutesBefore Int      @default(30)
  queueIntakeEnabled           Boolean  @default(true)
  bookingEnabled               Boolean  @default(true)
  walkInEnabled                Boolean  @default(true)
  manualWaitMinutes            Int?
  lineOaEnabled                Boolean  @default(false)
  ownerLineUserId              String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model ShopDateAvailability {
  id             String   @id @default(cuid())
  date           DateTime @unique
  bookingEnabled Boolean  @default(true)
  walkInEnabled  Boolean  @default(true)
  inStoreOnly    Boolean  @default(false)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

model ShopWeeklyAvailability {
  id             String   @id @default(cuid())
  dayOfWeek      Int      @unique
  bookingEnabled Boolean  @default(true)
  walkInEnabled  Boolean  @default(true)
  inStoreOnly    Boolean  @default(false)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dayOfWeek])
}

model RateLimitBucket {
  key             String    @id
  count           Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}

model PilotCohort {
  id                String                   @id
  evidenceExpiresAt DateTime                 @db.Timestamptz(3)
  pilotEndDate      DateTime?                @db.Date
  shopTimezone      String?
  approvalRef       String?
  createdAt         DateTime                 @default(now())
  queueItems        QueueItem[]
  operations        QueueMutationOperation[]
  events            QueueEvent[]
  notificationLogs  NotificationLog[]
}

model PilotClassificationAudit {
  id                 String                   @id
  queueItemId        String
  queueItem          QueueItem                @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  fromClassification PilotQueueClassification
  toClassification   PilotQueueClassification
  reason             String
  operatorId         String
  reviewedRestore    Boolean                  @default(false)
  createdAt          DateTime                 @default(now()) @db.Timestamptz(3)

  @@index([queueItemId, createdAt])
}

model QueueMutationOperation {
  id                  String                   @id
  mutationSource      QueueEventMutationSource
  primaryQueueItemId  String?
  primaryQueueItem    QueueItem?               @relation("PrimaryQueueOperation", fields: [primaryQueueItemId], references: [id], onDelete: SetNull)
  outcome             QueueMutationOutcome?
  pilotCohortId       String
  pilotCohort         PilotCohort              @relation(fields: [pilotCohortId], references: [id], onDelete: Restrict)
  pilotReleaseSegment String
  createdAt           DateTime                 @default(now())
  completedAt         DateTime?
  events              QueueEvent[]
  notifications       NotificationLog[]

  @@index([pilotCohortId, createdAt])
  @@index([primaryQueueItemId, createdAt])
}

model QueueEvent {
  id                  String                   @id @default(cuid())
  operationId         String
  operation           QueueMutationOperation   @relation(fields: [operationId], references: [id], onDelete: Cascade)
  role                QueueEventRole
  eventOrdinal        Int
  queueItemId         String
  queueItem           QueueItem                @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  type                QueueEventType
  actor               QueueEventActor
  mutationSource      QueueEventMutationSource
  reason              QueueEventReason?
  schemaVersion       Int                      @default(1)
  sequence            Int
  effectiveAt         DateTime
  recordedAt          DateTime                 @default(now())
  pilotCohortId       String
  pilotCohort         PilotCohort              @relation(fields: [pilotCohortId], references: [id], onDelete: Restrict)
  pilotReleaseSegment String
  fromStatus          QueueItemStatus?
  toStatus            QueueItemStatus?
  fromStartAt         DateTime?
  toStartAt           DateTime?
  fromEstimatedAt     DateTime?
  toEstimatedAt       DateTime?
  fromArrivedAt       DateTime?
  toArrivedAt         DateTime?
  fromStartedAt       DateTime?
  toStartedAt         DateTime?
  fromCompletedAt     DateTime?
  toCompletedAt       DateTime?
  fromCancelledAt     DateTime?
  toCancelledAt       DateTime?
  fromNoShowAt        DateTime?
  toNoShowAt          DateTime?
  fromServiceId       String?
  toServiceId         String?
  reorderIntent       QueueReorderIntent?
  correctsEventId     String?
  correctsEvent       QueueEvent?              @relation("QueueEventCorrection", fields: [correctsEventId], references: [id], onDelete: SetNull)
  corrections         QueueEvent[]             @relation("QueueEventCorrection")

  @@unique([operationId, eventOrdinal])
  @@unique([queueItemId, sequence])
  @@index([pilotCohortId, effectiveAt])
  @@index([queueItemId, effectiveAt])
  @@index([recordedAt])
}

model EvidenceHold {
  id          String             @id @default(cuid())
  queueItemId String
  queueItem   QueueItem          @relation(fields: [queueItemId], references: [id], onDelete: Restrict)
  reason      EvidenceHoldReason
  approvedBy  String
  startsAt    DateTime           @default(now())
  expiresAt   DateTime
  releasedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([queueItemId])
  @@index([expiresAt, releasedAt])
}

model OwnerLineConnectToken {
  nonce      String    @id
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
  @@index([consumedAt])
}
