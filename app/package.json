{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node scripts/seed-services.mjs",
    "privacy:prune": "node scripts/prune-customer-data.mjs",
    "pilot:cohort": "node scripts/manage-pilot-cohort.mjs",
    "pilot:report": "node scripts/generate-pilot-report.mjs",
    "pilot:classify": "node scripts/classify-pilot-queue.mjs",
    "pilot:hold": "node scripts/manage-evidence-hold.mjs",
    "pilot:correct": "node scripts/correct-pilot-event.mjs",
    "pilot:subject-request": "node scripts/process-customer-data-request.mjs",
    "pilot:daily-close:validate": "node scripts/validate-pilot-daily-close.mjs",
    "db:deploy": "prisma migrate deploy",
    "deploy:start": "prisma migrate deploy && next start -H 0.0.0.0 -p ${PORT:-3000}"
  },
  "dependencies": {
    "@iconify-json/lucide": "1.2.115",
    "@iconify/react": "6.0.2",
    "@line/liff": "2.29.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-alert-dialog": "1.1.17",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-separator": "1.1.10",
    "@radix-ui/react-slot": "1.3.0",
    "clsx": "2.1.1",
    "next": "16.2.9",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "20.19.43",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
